{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sashakang/ai-workspace/core-aiws/contracts/plugin-contract.schema.json",
  "title": "AI Workspace Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "plugin_id",
    "version",
    "public_skills",
    "public_agents",
    "dependencies",
    "project_memory_read_scope",
    "project_memory_write_scope",
    "shared_memory_read_scope",
    "shared_memory_write_scope",
    "improve_targets"
  ],
  "properties": {
    "plugin_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "public_skills": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "public_agents": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "project_memory_read_scope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "project_memory_write_scope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "shared_memory_read_scope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "shared_memory_write_scope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "improve_targets": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
